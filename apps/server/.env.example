# ── Premon (Monad) server configuration ──

# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Monad chain
MONAD_NETWORK=testnet                       # testnet | mainnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz # JSON-RPC endpoint (required)
# MONAD_CHAIN_ID=10143                       # optional override (default per network)

# USDC token used for x402 + min-balance defaults.
# IMPORTANT: the bundled default is a PLACEHOLDER. Set this to the real Monad
# testnet USDC contract before relying on token metadata / x402.
# MONAD_USDC_ADDRESS=0x...
MONAD_USDC_DECIMALS=6

# Reputation / allowlists (comma-separated 0x addresses)
# RISKY_CONTRACT_IDS=0x...
# KNOWN_SAFE_CONTRACT_IDS=0x...

# Auth
# DELTAG_API_KEYS=key1,key2                  # empty = open (dev only)
# DELTAG_AUTH_MODE=api_key                   # api_key | x402 | both

# Limits
MAX_SIMULATION_OPERATIONS=20
REQUEST_TIMEOUT_MS=25000
DELTAG_RATE_LIMIT_MAX=200
DELTAG_RATE_LIMIT_WINDOW_MS=60000
# DELTAG_TRUST_PROXY=1

# x402 (optional)
# X402_ENABLED=true
# X402_PAY_TO=0x...                          # required when x402 enabled
# X402_FACILITATOR_URL=https://www.x402.org/facilitator
# X402_NETWORK=eip155:10143
# X402_ANALYZE_PRICE=$0.001
