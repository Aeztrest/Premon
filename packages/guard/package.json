{
  "name": "@premon/guard",
  "version": "0.1.0",
  "description": "Premon pre-sign transaction guard SDK for Monad / EVM (chain-light, no ethers required to consume).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": ["monad", "evm", "ethereum", "wallet", "security", "transaction", "firewall", "x402", "premon"],
  "homepage": "https://premon.vercel.app",
  "repository": { "type": "git", "url": "git+https://github.com/Aeztrest/Premon.git", "directory": "packages/guard" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
